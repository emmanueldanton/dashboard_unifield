# Auth-api (identique aux autres apps du monorepo, slug = unifield)
AUTH_API_BASE_URL=https://auth-api.cad42.internal
AUTH_API_SERVICE_CONSUMER_NAME=unifield
AUTH_API_SERVICE_CONSUMER_SECRET=<vault smsi>

# URL publique (returnTo du flow Microsoft)
UNIFIELD_PUBLIC_URL=https://security42.francecentral.cloudapp.azure.com/unifield
PUBLIC_URL=http://localhost:8050

# Application
APP_ENV=development
BASE_PATH=/unifield/
NODE_PROXY=false            # true en prod (Node gère l'auth avant proxy)

# Node shell
NODE_PORT=3005

# Gunicorn (loopback uniquement en prod)
PORT=8050
DASH_INTERNAL_URL=http://127.0.0.1:8050

# MongoDB Atlas
UNIFIELD_MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
UNIFIELD_MONGO_DB=unifield

# Mailgun
MAILGUN_API_KEY=<key>
MAILGUN_WEBHOOK_SIGNING_KEY=<signing_key>

# Dev bypass — JAMAIS en production (requiert aussi APP_ENV != production)
UNIFIELD_DEV_AUTH_BYPASS=false
