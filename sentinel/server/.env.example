# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3005
BASE_PATH=/sentinel
SENTINEL_PUBLIC_URL=https://security42.francecentral.cloudapp.azure.com/sentinel

# ── Auth SSO (auth-api ServiceConsumer, slug immuable "sentinel") ───────────────
AUTH_API_BASE_URL=https://auth-api.cad42.com
AUTH_API_SERVICE_CONSUMER_NAME=sentinel
AUTH_API_SERVICE_CONSUMER_SECRET=<vault smsi>

# Bypass auth — DEV LOCAL UNIQUEMENT (ignore en production / NODE_ENV=production).
# true => connexion auto en admin (dev@cad42.local), aucun login Microsoft requis.
SENTINEL_DEV_AUTH_BYPASS=false

# ── MongoDB ─────────────────────────────────────────────────────────────────────
# MONGO_DB     : base de lecture UNIFIELD (projets / trackers / units / events)
# SENTINEL_DB  : base d'ecriture Sentinel (snapshots, alert_history, alert_rules)
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/
MONGO_DB=unifield
SENTINEL_DB=cad42Users

# Cache memoire : intervalle de rafraichissement des donnees (defaut 900s = 15 min)
CACHE_REFRESH_SEC=900

# ── Scheduler / alertes ──────────────────────────────────────────────────────────
ALERT_INTERVAL_MIN=10
ALERT_RECIPIENTS=ops@cad42.com

# ── Mailgun (EU) ─────────────────────────────────────────────────────────────────
MAILGUN_API_KEY=<key>
MAILGUN_DOMAIN=<domain>
# Reserve (verification des webhooks entrants) — non utilise par l'envoi sortant
MAILGUN_WEBHOOK_SIGNING_KEY=<signing_key>
